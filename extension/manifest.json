{
	"manifest_version": 3,
	"name": "Fullscreen \"Cinema mode\" on YouTube and other quality-of-life improvements",
	"short_name": "Fullscreen YouTube and more",
	"description": "Browser extension that makes YouTube \"Cinema mode\" truly in fullscreen and some shortcut focus fixes.",
	"author": "ISh- (imwaves@gmail.com)",
	"homepage_url": "https://github.com/ish-/ext-youtube-cinema-fullscreen",
	"version": "0.1",
	"version_name": "0.1",
	"minimum_chrome_version": "88.0",
	"background": {
		"service_worker": "background.js",
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": ["https://*.youtube.com/*"],
			"js": ["content.js"]
		}
	],
	"options_ui": {
    "page": "options.html"
  },
  "icons": {
  	"128": "icon128.png"
  },
	"web_accessible_resources": [{
		"resources": ["content_injection.js"],
		"matches": ["https://*.youtube.com/*"]
	}],
	"permissions": [
		"scripting",
		"storage"
	],
	"host_permissions": [
		"https://*.youtube.com/*"
	]
}
